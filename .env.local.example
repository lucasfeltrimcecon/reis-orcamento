# Copie este arquivo como .env.local e preencha com as credenciais do seu projeto Supabase.
# .env.local NUNCA deve ser commitado (já está no .gitignore).

# Painel Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Service role (apenas server-side; NÃO prefixe com NEXT_PUBLIC_)
# Usado em rotas que precisam bypassar RLS — não usaremos na V1 da Fase 1.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui
